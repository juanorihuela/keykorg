# Configuración para distros Debian-based (Ubuntu, Linux Mint, Pop!_OS, etc.)
# Copiar como .env.debian y ajustar los valores según el entorno.

# Sistema operativo — debe coincidir con una clave activa de SO_CATALOG en constants.py
SO=debian

# Substring del nombre del dispositivo MIDI (tal como aparece en `aconnect -l` o `amidi -l`)
MIDI_DEVICE=

# Directorio de archivos de sonido — path relativo a la raíz del proyecto
SOUNDS_DIR=src/static/sounds

# Archivo raíz de comandos MIDI — path relativo a la raíz del proyecto
COMMANDS_FILE=src/config/commands/commands.debian.yaml

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
